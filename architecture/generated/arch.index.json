{
  "containers": [
    {
      "depends_on": [
        "broker",
        "db",
        "identity"
      ],
      "description": "HTTP + WebSocket API layer — routes, request/response types, auth extractors, WS handlers",
      "id": "api",
      "modules": [
        {
          "boundary": "HTTP boundary only — no business logic, no SQL",
          "depends_on": [
            "broker/state",
            "broker/delivery"
          ],
          "file": "",
          "files": [
            "mod.rs",
            "routes.rs"
          ],
          "id": "api/routes",
          "owns": [
            "http-endpoints",
            "request-types",
            "response-types",
            "AppState"
          ]
        },
        {
          "boundary": "Connection management only — no delivery decisions",
          "depends_on": [
            "broker/state",
            "broker/delivery"
          ],
          "file": "ws.rs",
          "files": [],
          "id": "api/ws",
          "owns": [
            "websocket-handler",
            "connection-upgrade",
            "live-streaming",
            "HttpFrame-dispatch"
          ]
        },
        {
          "boundary": "Header extraction and credential validation only — no route logic",
          "depends_on": [
            "broker/state"
          ],
          "file": "auth.rs",
          "files": [],
          "id": "api/auth",
          "owns": [
            "ProjectAuth",
            "AgentAuth",
            "AdminAuth",
            "header-extraction",
            "auth-extractors"
          ]
        },
        {
          "boundary": "Operator-level management only — no tenant routing or delivery logic",
          "depends_on": [
            "broker/state",
            "api/auth"
          ],
          "file": "admin.rs",
          "files": [],
          "id": "api/admin",
          "owns": [
            "admin_router",
            "list_projects",
            "get_stats",
            "project_stats",
            "delete_project",
            "suspend_project",
            "unsuspend_project"
          ]
        },
        {
          "boundary": "Rate limiting only — reads X-Project header, no broker or DB calls",
          "depends_on": [
            "api/routes"
          ],
          "file": "middleware.rs",
          "files": [],
          "id": "api/middleware",
          "owns": [
            "ProjectRateLimiter",
            "rate_limit_middleware"
          ]
        }
      ],
      "path": "broker/src/api"
    },
    {
      "depends_on": [
        "db",
        "identity"
      ],
      "description": "Core broker logic — agent state, presence, delivery engine, channel routing, nonce store",
      "id": "broker",
      "modules": [
        {
          "boundary": "In-memory state + DB sync — no HTTP/WS concerns",
          "depends_on": [
            "db/db"
          ],
          "file": "",
          "files": [
            "mod.rs",
            "state.rs"
          ],
          "id": "broker/state",
          "owns": [
            "agent-sessions",
            "presence-tracking",
            "agent-discovery",
            "channel-broadcast",
            "BrokerState",
            "AgentKey"
          ]
        },
        {
          "boundary": "Delivery drain only — no SQL construction, no fan-out",
          "depends_on": [
            "db/db"
          ],
          "file": "delivery.rs",
          "files": [],
          "id": "broker/delivery",
          "owns": [
            "pending-drain",
            "cleanup",
            "DeliveryEngine"
          ]
        },
        {
          "boundary": "In-memory challenge nonce management — stateful, belongs in broker layer not identity layer",
          "depends_on": [
            "identity/ed25519"
          ],
          "file": "nonce.rs",
          "files": [],
          "id": "broker/nonce",
          "owns": [
            "NonceStore",
            "nonce-issuance",
            "nonce-consumption",
            "nonce-eviction"
          ]
        }
      ],
      "path": "broker/src/broker"
    },
    {
      "depends_on": [
        "identity"
      ],
      "description": "SQLite persistence — schema, migrations, repository pattern for all data access",
      "id": "db",
      "modules": [
        {
          "boundary": "Connection management and migration only — no queries beyond DDL",
          "depends_on": [],
          "file": "mod.rs",
          "files": [],
          "id": "db/db",
          "owns": [
            "database-connection",
            "sqlite-handle",
            "open",
            "open_memory",
            "migrate"
          ]
        },
        {
          "boundary": "Schema DDL only — no DML queries",
          "depends_on": [],
          "file": "schema.rs",
          "files": [],
          "id": "db/schema",
          "owns": [
            "migrations",
            "table-definitions",
            "ensure_schema"
          ]
        },
        {
          "boundary": "Pure persistence — all SQL lives here, no business logic",
          "depends_on": [
            "db/db",
            "identity/secret"
          ],
          "file": "repository.rs",
          "files": [],
          "id": "db/repository",
          "owns": [
            "Repository",
            "PendingMessage",
            "register_project",
            "register_agent",
            "agent_exists",
            "project_exists",
            "ensure_channel",
            "channel_exists",
            "is_cross_project_allowed",
            "seed_cross_project_default",
            "get_subscribers",
            "subscribe",
            "unsubscribe",
            "insert_message",
            "record_pending",
            "record_delivered",
            "drain_pending",
            "peek_pending",
            "cleanup",
            "find_agents_by_name"
          ]
        }
      ],
      "path": "broker/src/db"
    },
    {
      "depends_on": [],
      "description": "Authentication primitives — key hashing, hash verification, Ed25519 signature verification",
      "id": "identity",
      "modules": [
        {
          "boundary": "Pure crypto — no network, no DB, no stanza concerns",
          "depends_on": [],
          "file": "",
          "files": [
            "mod.rs",
            "secret.rs"
          ],
          "id": "identity/secret",
          "owns": [
            "ensure_broker_secret",
            "hash_key",
            "verify_key_hash"
          ]
        },
        {
          "boundary": "Pure crypto — deterministic, no state, no randomness, no DB",
          "depends_on": [],
          "file": "ed25519.rs",
          "files": [],
          "id": "identity/ed25519",
          "owns": [
            "build_challenge_payload",
            "verify_agent_signature",
            "VerifyError"
          ]
        }
      ],
      "path": "broker/src/identity"
    },
    {
      "depends_on": [],
      "description": "MCP server (stdio) — exposes broker tools for AI agents (register, presence, send, peek, messages)",
      "id": "mcp",
      "modules": [
        {
          "boundary": "MCP adapter only — constructs HttpFrame requests to broker /v1/send, formats responses. No business logic.",
          "depends_on": [
            "mcp/session"
          ],
          "file": "",
          "files": [
            "main.rs",
            "tools.rs"
          ],
          "id": "mcp/tools",
          "owns": [
            "BrokerTools",
            "broker_register",
            "broker_presence",
            "broker_send",
            "broker_frame_post",
            "broker_peek",
            "broker_messages",
            "send_raw"
          ]
        },
        {
          "boundary": "Pure FS + in-memory state — no broker dependencies, no HTTP client logic",
          "depends_on": [],
          "file": "session.rs",
          "files": [],
          "id": "mcp/session",
          "owns": [
            "SessionManager",
            "load_key",
            "lookup_identity",
            "credential-persistence",
            "identity-persistence"
          ]
        }
      ],
      "path": "mcp/src"
    }
  ],
  "rules": [
    {
      "id": "db-independence",
      "reason": "Database layer must not depend on broker logic or API",
      "type": "no_dependency"
    },
    {
      "id": "broker-no-api",
      "reason": "Broker logic must not depend on API layer — API calls broker, not the other way",
      "type": "no_dependency"
    },
    {
      "id": "identity-independence",
      "reason": "Identity is a leaf module — pure crypto, no dependencies on other layers",
      "type": "no_dependency"
    },
    {
      "id": "session-independence",
      "reason": "SessionManager is a leaf — pure FS + in-memory state, no broker dependencies",
      "type": "no_dependency"
    },
    {
      "id": "identity-callers",
      "reason": "Crypto primitives used by persistence layer (hash_key/verify_key_hash), nonce store (build_challenge_payload), and WS auth handler (verify_agent_signature)",
      "type": "restrict_callers_to"
    },
    {
      "id": "db-callers",
      "reason": "Persistence accessed by broker core and API layer (PendingMessage, ProjectInfo, BrokerStats response types). NOTE: aspirational direction is broker-only — direct db type imports in api/* are a known boundary smell (REF-04)",
      "type": "restrict_callers_to"
    },
    {
      "id": "broker-callers",
      "reason": "Core broker logic exposed only through the API surface",
      "type": "restrict_callers_to"
    }
  ],
  "stories": [
    {
      "description": "Agent connects via WebSocket, registers presence, receives pending messages",
      "flow": [
        "api/ws",
        "broker/state",
        "broker/delivery"
      ],
      "id": "agent-connects"
    },
    {
      "description": "Agent sends a message to another agent or channel, broker persists and routes",
      "flow": [
        "api/ws",
        "broker/delivery",
        "broker/state"
      ],
      "id": "agent-sends-message"
    },
    {
      "description": "Client queries which agents are online, filtered by project or state",
      "flow": [
        "api/routes",
        "broker/state"
      ],
      "id": "discover-agents"
    }
  ],
  "system": {
    "description": "Lightweight agent message broker — identity, presence, and message routing for AI agents across projects.",
    "name": "agent-broker"
  }
}