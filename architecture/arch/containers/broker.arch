ARCH: 0.4
CONT: broker
PATH: broker/src/broker
DEP: db; identity
DESC: Core broker logic — agent state, presence, delivery engine, channel routing, nonce store

MOD: state
  FILES: mod.rs; state.rs
  OWN: agent-sessions; presence-tracking; agent-discovery; channel-broadcast; BrokerState; AgentKey
  BND: In-memory state + DB sync — no HTTP/WS concerns
  DEP: db/db

MOD: delivery
  FILE: delivery.rs
  OWN: pending-drain; cleanup; DeliveryEngine
  BND: Delivery drain only — no SQL construction, no fan-out
  DEP: db/db

MOD: nonce
  FILE: nonce.rs
  OWN: NonceStore; nonce-issuance; nonce-consumption; nonce-eviction
  BND: In-memory challenge nonce management — stateful, belongs in broker layer not identity layer
  DEP: identity/ed25519
