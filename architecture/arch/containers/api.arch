ARCH: 0.4
CONT: api
PATH: broker/src/api
DEP: broker; db; identity
DESC: HTTP + WebSocket API layer — routes, request/response types, auth extractors, WS handlers

MOD: routes
  FILES: mod.rs; routes.rs
  OWN: http-endpoints; request-types; response-types; AppState
  BND: HTTP boundary only — no business logic, no SQL
  DEP: broker/state; broker/delivery
  ROUTES: POST /projects/register; POST /projects/{name}/rotate-key; POST /agents/register; POST /agents/{name}/rekey; PATCH /agents/{name}; GET /agents; PUT /presence; POST /v1/send; GET /messages; GET /messages/peek; GET /health; GET /tools; PUT /tools/{name}; GET /tools/{name}; DELETE /tools/{name}

MOD: ws
  FILE: ws.rs
  OWN: websocket-handler; connection-upgrade; live-streaming; HttpFrame-dispatch
  BND: Connection management only — no delivery decisions
  DEP: broker/state; broker/delivery

MOD: auth
  FILE: auth.rs
  OWN: ProjectAuth; AgentAuth; AdminAuth; header-extraction; auth-extractors
  BND: Header extraction and credential validation only — no route logic
  DEP: broker/state

MOD: admin
  FILE: admin.rs
  OWN: admin_router; list_projects; get_stats; project_stats; delete_project; suspend_project; unsuspend_project
  BND: Operator-level management only — no tenant routing or delivery logic
  DEP: broker/state; api/auth

MOD: middleware
  FILE: middleware.rs
  OWN: ProjectRateLimiter; rate_limit_middleware
  BND: Rate limiting only — reads X-Project header, no broker or DB calls
  DEP: api/routes
