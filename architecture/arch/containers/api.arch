ARCH: 0.4
CONT: api
PATH: broker/src/api
DEP: broker; db; identity; stanza
DESC: HTTP + WebSocket API layer — routes, request/response types, auth extractors, WS handlers

MOD: routes
  FILES: mod.rs; routes.rs
  OWN: http-endpoints; request-types; response-types; AppState
  BND: HTTP boundary only — no business logic, no SQL
  DEP: broker/state; broker/delivery; stanza/types
  ROUTES: POST /projects/register; POST /agents/register; GET /agents; PUT /presence; POST /send; GET /messages; GET /messages/peek; POST /channels/{id}/subscribe; DELETE /channels/{id}/unsubscribe; GET /health

MOD: ws
  FILE: ws.rs
  OWN: websocket-handler; connection-upgrade; live-streaming; WS-stanza-dispatch
  BND: Connection management only — no delivery decisions
  DEP: broker/state; broker/delivery; stanza/types; stanza/parser

MOD: auth
  FILE: auth.rs
  OWN: ProjectAuth; AgentAuth; header-extraction; auth-extractors
  BND: Header extraction and credential validation only — no route logic
  DEP: broker/state
